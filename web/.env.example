# Copy this file to .env and fill in your Supabase project's values
# (Project Settings > API in the Supabase dashboard).
#
# Until these are set, the app falls back to the bundled static JSON in
# public/species_data.json for reference data, and the "내 어항" (My Tanks)
# tab shows a setup notice instead of the login form.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
